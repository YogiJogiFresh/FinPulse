{
  "name": "finpulse-electron",
  "version": "1.4.4",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "sql.js": "^1.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.finpulse.app",
    "productName": "FinPulse",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/sql.js/dist/sql-wasm.js"
    ],
    "extraResources": [
      {
        "from": "../client/dist",
        "to": "client"
      },
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FinPulse",
      "uninstallDisplayName": "FinPulse"
    },
    "publish": {
      "provider": "github",
      "owner": "YogiJogiFresh",
      "repo": "FinPulse"
    }
  }
}
